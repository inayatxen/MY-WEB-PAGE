{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/spa",
  "env": {
    "PING_MESSAGE": "@inayatxen"
  },
  "functions": {
    "server/index.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/server/index.ts"
    }
  ]
}
